# ==================== CONFIGURACIÓN DOCTOR PC ====================
# Copia este archivo a .env y completa con tus valores reales

# ==================== BASE DE DATOS ====================
# MongoDB Atlas connection string
# Formato: mongodb+srv://usuario:password@cluster.mongodb.net/
MONGODB_URI=mongodb+srv://tu_usuario:tu_password@cluster.mongodb.net/

# ==================== AUTENTICACIÓN ====================
# Secreto para firmar tokens JWT (usa una cadena aleatoria larga y segura)
# Genera uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_secreto_jwt_muy_seguro_y_largo_aqui

# Contraseña del usuario administrador inicial
# Este usuario se crea automáticamente al iniciar el sistema
ADMIN_PASSWORD=tu_password_admin_seguro

# ==================== CORS ====================
# Orígenes permitidos para CORS (separados por comas)
# Desarrollo local: http://localhost:3000
# Producción: https://tu-dominio.netlify.app
ALLOWED_ORIGINS=http://localhost:3000,https://tu-dominio.netlify.app

# ==================== INTEGRACIÓN DECOLECTA (Consulta DNI) ====================
# API de DECOLECTA para consultar datos de RENIEC por DNI
# Obtén tu API Key en: https://decolecta.com
DECOLECTA_URL=https://api.decolecta.com
DECOLECTA_API_KEY=tu_api_key_de_decolecta

# ==================== WHATSAPP CLOUD API (Opcional) ====================
# Configuración para envío de reportes por WhatsApp
# Obtén credenciales en: https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_TOKEN=tu_token_de_whatsapp_cloud_api
WHATSAPP_PHONE_ID=tu_phone_number_id
WHATSAPP_BUSINESS_ID=tu_business_account_id

# ==================== CLOUDINARY (Fotos de Servicios) ====================
# Obtén credenciales en: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=dcedzwks4
CLOUDINARY_API_KEY=642919761475517
CLOUDINARY_API_SECRET=Jf1R7oSSRHELMk4uVQabPd9YNwo

# ==================== ENTORNO ====================
# Entorno de ejecución (development, production)
NODE_ENV=development

# Puerto para servidor local (solo desarrollo)
PORT=3000

# ==================== NOTAS ====================
# 1. NUNCA subas el archivo .env a Git (ya está en .gitignore)
# 2. En Netlify, configura estas variables en: Site settings > Environment variables
# 3. Las variables WHATSAPP_* son opcionales si no usas esa funcionalidad
# 4. DECOLECTA_* es opcional si no usas consulta de DNI automática
